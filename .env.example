# ─── Database ──────────────────────────────────────────────────────────────
POSTGRES_USER=bingo
POSTGRES_PASSWORD=bingo
POSTGRES_DB=bingo
POSTGRES_PORT=5432

# Used by the app + drizzle-kit. In docker-compose the host is `db`.
# For local dev outside docker, change to: postgres://bingo:bingo@localhost:5432/bingo
DATABASE_URL=postgres://bingo:bingo@localhost:5432/bingo

# ─── App ───────────────────────────────────────────────────────────────────
APP_PORT=3000

# ─── Better Auth ───────────────────────────────────────────────────────────
# Public base URL of the app — used for OAuth redirects & cookie scope.
BETTER_AUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-long-random-string

# ─── OAuth providers ───────────────────────────────────────────────────────
# Discord: https://discord.com/developers/applications  (redirect: <BETTER_AUTH_URL>/api/auth/callback/discord)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# GitHub:  https://github.com/settings/developers       (redirect: <BETTER_AUTH_URL>/api/auth/callback/github)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
